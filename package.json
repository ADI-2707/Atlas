{
  "name": "atlas",
  "version": "1.0.0",
  "description": "Atlas Enterprise Application Framework — A modular, event-driven platform for building enterprise software.",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter frontend --filter saas-portal --filter @atlas/backend dev",
    "build": "pnpm -r build",
    "lint": "pnpm --parallel -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "pnpm -r clean && rimraf node_modules",
    "test": "pnpm -r test"
  },
  "keywords": [
    "enterprise",
    "framework",
    "plugin-architecture",
    "modular",
    "erp"
  ],
  "author": "Aditya Singh",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "prettier": "3.4.2",
    "typescript": "5.6.3",
    "rimraf": "6.0.1"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
