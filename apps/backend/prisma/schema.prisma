datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["atlas_core", "atlas_inventory", "atlas_crm", "atlas_hr", "atlas_pm"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  roles          Role[]
  auditLogs      AuditLog[]
  supportTickets SupportTicket[]
  pluginData     PluginData[]

  healthScore Float @default(100.0) @map("health_score")
  mrr         Float @default(0.0)

  @@map("organizations")
  @@schema("atlas_core")
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String       @map("password_hash")
  firstName         String       @map("first_name")
  lastName          String       @map("last_name")
  status            String       @default("ACTIVE") // ACTIVE, INACTIVE
  hasCompletedSetup Boolean      @default(false) @map("has_completed_setup")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  organizationId    String       @map("organization_id")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  roles     Role[]     @relation("UserRoles")
  sessions  Session[]
  auditLogs AuditLog[]

  @@map("users")
  @@schema("atlas_core")
}

model Role {
  id             String        @id @default(uuid())
  name           String
  description    String?
  isSystem       Boolean       @default(false) @map("is_system")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")

  @@unique([name, organizationId])
  @@map("roles")
  @@schema("atlas_core")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  module      String   @default("core") // core, inventory, crm, etc.
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles Role[] @relation("RolePermissions")

  @@map("permissions")
  @@schema("atlas_core")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @map("refresh_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  expiresAt    DateTime @map("expires_at")
  lastActivity DateTime @default(now()) @map("last_activity")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sessions")
  @@schema("atlas_core")
}

model Plugin {
  id          String   @id
  name        String
  version     String
  description String?
  status      String   @default("INSTALLED") // INSTALLED, ENABLED, DISABLED
  config      Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  data        PluginData[]

  @@map("plugins")
  @@schema("atlas_core")
}

model PluginData {
  id             String       @id @default(uuid())
  pluginId       String       @map("plugin_id")
  organizationId String       @map("organization_id")
  entityType     String       @map("entity_type")
  data           Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin         Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@index([pluginId, organizationId, entityType])
  @@map("plugin_data")
  @@schema("atlas_core")
}

model AuditLog {
  id             String        @id @default(uuid())
  timestamp      DateTime      @default(now())
  userId         String?       @map("user_id")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  pluginId       String?       @map("plugin_id")
  action         String
  result         String
  ipAddress      String?       @map("ip_address")
  sessionId      String?       @map("session_id")
  details        Json?         @default("{}")

  @@map("audit_logs")
  @@schema("atlas_core")
}

// Inventory Plugin Schema moved to plugins/inventory/backend/prisma/schema.prisma

// -----------------------------------------
// CRM PLUGIN SCHEMA
// -----------------------------------------

model Customer {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  email          String
  phone          String?
  company        String?
  status         String   @default("LEAD") // LEAD, PROSPECT, CUSTOMER, CHURNED
  customData     Json?    @default("{}") @map("custom_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  deals Deal[]

  @@unique([organizationId, email])
  @@map("crm_customers")
  @@schema("atlas_crm")
}

model Deal {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  title          String
  customerId     String   @map("customer_id")
  stage          String   @default("QUALIFICATION") // QUALIFICATION, PROPOSAL, NEGOTIATION, CLOSED_WON, CLOSED_LOST
  value          Float    @default(0.0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lineItems DealItem[]

  @@map("crm_deals")
  @@schema("atlas_crm")
}

model DealItem {
  id             String   @id @default(uuid())
  dealId         String   @map("deal_id")
  productId      String   @map("product_id")
  quantity       Int
  priceAtTime    Float    @map("price_at_time")
  createdAt      DateTime @default(now()) @map("created_at")

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("crm_deal_items")
  @@schema("atlas_crm")
}

// -----------------------------------------
// HR PLUGIN SCHEMA
// -----------------------------------------

model Employee {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  userId          String?   @unique @map("user_id") // optional link to a platform login
  employeeCode    String // human-friendly ID, e.g. EMP-0001
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String
  phone           String?
  jobTitle        String?   @map("job_title")
  departmentId    String?   @map("department_id")
  managerId       String?   @map("manager_id")
  employmentType  String    @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT, INTERN
  status          String    @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  hireDate        DateTime  @map("hire_date")
  terminationDate DateTime? @map("termination_date")
  customData      Json?     @default("{}") @map("custom_data")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager        Employee?       @relation("ManagerReports", fields: [managerId], references: [id], onDelete: SetNull)
  reports        Employee[]      @relation("ManagerReports")
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  payrollRecords PayrollRecord[]

  @@unique([organizationId, employeeCode])
  @@unique([organizationId, email])
  @@map("hr_employees")
  @@schema("atlas_hr")
}

model Department {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  headEmployeeId String?  @map("head_employee_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employees Employee[]

  @@unique([organizationId, name])
  @@map("hr_departments")
  @@schema("atlas_hr")
}

model LeaveRequest {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  employeeId     String   @map("employee_id")
  type           String // VACATION, SICK, UNPAID, OTHER
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  reason         String?
  approvedBy     String?  @map("approved_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hr_leave_requests")
  @@schema("atlas_hr")
}

model LeaveBalance {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  employeeId     String @map("employee_id")
  leaveType      String @map("leave_type")
  year           Int
  allocatedDays  Float  @default(0) @map("allocated_days")
  usedDays       Float  @default(0) @map("used_days")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveType, year])
  @@map("hr_leave_balances")
  @@schema("atlas_hr")
}

model PayrollRecord {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  employeeId     String   @map("employee_id")
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  grossPay       Float    @map("gross_pay")
  deductions     Float    @default(0)
  netPay         Float    @map("net_pay")
  status         String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  createdAt      DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hr_payroll_records")
  @@schema("atlas_hr")
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_logs")
  @@schema("atlas_core")
}

model SupportTicket {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subject        String
  description    String
  status         String       @default("OPEN")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("support_tickets")
  @@schema("atlas_core")
}

// -----------------------------------------
// PROJECT MANAGEMENT PLUGIN SCHEMA
// -----------------------------------------

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  key            String
  description    String?
  parentId       String?  @map("parent_id")
  status         String   @default("ACTIVE") // ACTIVE, ON_HOLD, COMPLETED
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parentProject  Project?  @relation("SubProjects", fields: [parentId], references: [id], onDelete: SetNull)
  subProjects    Project[] @relation("SubProjects")
  boards         Board[]
  issues         Issue[]
  lineups        Lineup[]
  errorLogs      ErrorLog[]

  @@unique([organizationId, key])
  @@map("pm_projects")
  @@schema("atlas_pm")
}

model Board {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("pm_boards")
  @@schema("atlas_pm")
}

model Issue {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  reporterId     String?  @map("reporter_id")
  assigneeId     String?  @map("assignee_id")
  title          String
  description    String?
  status         String   @default("TODO") // TODO, IN_PROGRESS, DONE
  lineupId       String?  @map("lineup_id")
  priority       String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  issueType      String   @default("TASK") // TASK, BUG, EPIC
  startDate      DateTime? @map("start_date")
  dueDate        DateTime? @map("due_date")
  estimateHours  Float?   @map("estimate_hours")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineup   Lineup?   @relation(fields: [lineupId], references: [id], onDelete: SetNull)
  comments Comment[]
  steps    Step[]

  @@map("pm_issues")
  @@schema("atlas_pm")
}

model Comment {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  issueId        String   @map("issue_id")
  authorId       String   @map("author_id")
  text           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@map("pm_comments")
  @@schema("atlas_pm")
}

model Step {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  issueId        String   @map("issue_id")
  title          String
  isCompleted    Boolean  @default(false) @map("is_completed")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@map("pm_steps")
  @@schema("atlas_pm")
}

model Lineup {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  projectId       String   @map("project_id")
  name            String
  order           Int      @default(0)
  allocatedUserId String?  @map("allocated_user_id") // Resource allocation on each step
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@map("pm_lineups")
  @@schema("atlas_pm")
}

model ErrorLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  message        String
  stackTrace     String?  @map("stack_trace")
  source         String   @default("SYSTEM") // SYSTEM, USER
  status         String   @default("UNRESOLVED") // UNRESOLVED, RESOLVED
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("pm_error_logs")
  @@schema("atlas_pm")
}
