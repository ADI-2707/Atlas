datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["atlas_core"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}


model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  tier      String   @default("starter") // starter, enterprise, custom
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  roles                Role[]
  auditLogs            AuditLog[]
  supportTickets       SupportTicket[]
  pluginData           PluginData[]
  invitations          Invitation[]
  organizationPlugins  OrganizationPlugin[]

  healthScore Float @default(100.0) @map("health_score")
  mrr         Float @default(0.0)

  @@map("organizations")
  @@schema("atlas_core")
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String       @map("password_hash")
  firstName         String       @map("first_name")
  lastName          String       @map("last_name")
  status            String       @default("ACTIVE") // ACTIVE, INACTIVE
  hasCompletedSetup Boolean      @default(false) @map("has_completed_setup")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  organizationId    String       @map("organization_id")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  roles         Role[]         @relation("UserRoles")
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
  @@schema("atlas_core")
}

model Role {
  id             String        @id @default(uuid())
  name           String
  description    String?
  isSystem       Boolean       @default(false) @map("is_system")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")

  @@unique([name, organizationId])
  @@map("roles")
  @@schema("atlas_core")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  module      String   @default("core") // core, inventory, crm, etc.
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles Role[] @relation("RolePermissions")

  @@map("permissions")
  @@schema("atlas_core")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @map("refresh_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  expiresAt    DateTime @map("expires_at")
  lastActivity DateTime @default(now()) @map("last_activity")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sessions")
  @@schema("atlas_core")
}

model Plugin {
  id          String   @id
  name        String
  version     String
  description String?
  status      String   @default("INSTALLED") // INSTALLED, ENABLED, DISABLED
  config      Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  data                PluginData[]
  organizationPlugins OrganizationPlugin[]

  @@map("plugins")
  @@schema("atlas_core")
}

model PluginData {
  id             String       @id @default(uuid())
  pluginId       String       @map("plugin_id")
  organizationId String       @map("organization_id")
  entityType     String       @map("entity_type")
  data           Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin         Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@index([pluginId, organizationId, entityType])
  @@map("plugin_data")
  @@schema("atlas_core")
}

model AuditLog {
  id             String        @id @default(uuid())
  timestamp      DateTime      @default(now())
  userId         String?       @map("user_id")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  pluginId       String?       @map("plugin_id")
  action         String
  result         String
  ipAddress      String?       @map("ip_address")
  sessionId      String?       @map("session_id")
  details        Json?         @default("{}")

  @@map("audit_logs")
  @@schema("atlas_core")
}

// Inventory Plugin Schema moved to plugins/inventory/backend/prisma/schema.prisma

// CRM, HR, and PM Plugin Schemas moved to plugins/*/backend/prisma/schema.prisma

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_logs")
  @@schema("atlas_core")
}

model SupportTicket {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subject        String
  description    String
  status         String       @default("OPEN")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("support_tickets")
  @@schema("atlas_core")
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleIds        String[]     @map("role_ids")
  status         String       @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([email, organizationId])
  @@map("invitations")
  @@schema("atlas_core")
}

model OrganizationPlugin {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  pluginId       String       @map("plugin_id")
  status         String       @default("ENABLED") // ENABLED, DISABLED
  config         Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin         Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([organizationId, pluginId])
  @@map("organization_plugins")
  @@schema("atlas_core")
}

model Notification {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  message        String
  type           String       @default("INFO") // INFO, SUCCESS, WARNING, ERROR, INVITATION
  isRead         Boolean      @default(false) @map("is_read")
  actionUrl      String?      @map("action_url")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("notifications")
  @@schema("atlas_core")
}

