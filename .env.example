# ===========================================
# Atlas Enterprise Application Framework
# Environment Configuration
# ===========================================

# Application
NODE_ENV=development
APP_NAME=Atlas
APP_PORT=3000
APP_URL=http://localhost:3000

# Frontend
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=atlas
DATABASE_USER=atlas
DATABASE_PASSWORD=atlas_dev_password
DATABASE_URL=postgresql://atlas:atlas_dev_password@localhost:5432/atlas?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=atlas-dev-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Storage
STORAGE_PATH=./storage

# Logging
LOG_LEVEL=debug
